{
  "name": "chattrix",
  "version": "1.0.0",
  "description": "Proximity-based random video/audio chat platform",
  "private": true,
  "scripts": {
    "server": "cd apps/server && npm run dev",
    "client": "cd apps/client && npm run dev",
    "dev": "npx concurrently \"npm run server\" \"npm run client\"",
    "build": "cd apps/client && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
