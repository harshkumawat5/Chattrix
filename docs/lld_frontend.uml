@startuml lld_frontend

' ───────────── COLORS ─────────────
!define GPS_COLOR #27AE60
!define IP_COLOR #E67E22
!define MATCH_COLOR #2980B9
!define SESSION_COLOR #8E44AD
!define RECORD_COLOR #C0392B
!define USER_COLOR #16A085
!define SOCKET_COLOR #1A5276
!define AUTH_COLOR #C0392B

' ───────────── SKINPARAM ─────────────
skinparam backgroundColor #FFFFFF
skinparam defaultFontColor #2C3E50
skinparam defaultFontSize 13
skinparam defaultFontName Arial

skinparam sequence {
  BackgroundColor #F8F9FA
  BorderColor #BDC3C7
  ActorBackgroundColor #16A085
  ActorBorderColor #2C3E50
  ActorFontColor #FFFFFF
  ParticipantBackgroundColor #ECF0F1
  ParticipantBorderColor #BDC3C7
  ParticipantFontColor #2C3E50
  ArrowColor #34495E
  ArrowFontColor #2C3E50
  LifeLineBorderColor #BDC3C7
  LifeLineBackgroundColor #ECF0F1
  NoteBackgroundColor #D6EAF8
  NoteBorderColor #2980B9
  NoteFontColor #2C3E50
  DividerBackgroundColor #ECF0F1
  DividerBorderColor #BDC3C7
  DividerFontColor #2C3E50
  GroupBackgroundColor #F2F3F4
  GroupBorderColor #BDC3C7
  GroupHeaderFontColor #34495E
}

skinparam note {
  BackgroundColor #D6EAF8
  BorderColor #2980B9
  FontColor #2C3E50
}

' ───────────── PARTICIPANTS ─────────────
actor       "👤 User"            as User    #16A085
participant "🖥 Browser / React"  as UI      #2980B9
participant "🗃 Zustand Store"    as Store   #8E44AD
participant "🔧 api.js"           as API     #E67E22
participant "🔌 socket.js"        as Socket  #1A5276
participant "🌐 Backend"          as Backend #C0392B

' ═══════════════════════════════════════════════════════
== 🟢 STEP 1 — Landing (Username Entry) ==
' ═══════════════════════════════════════════════════════

User -> UI : visits app

UI -> Store : read accessToken
note right of Store
  Persisted in localStorage via zustand/persist
  key: "chattrix-auth"
end note

alt Token exists in localStorage
  UI -> UI : decode JWT → check exp timestamp
  alt Token expired
    UI -> Store : clearAuth()
    UI --> User : show username entry screen
  else Token still valid
    UI -> Socket : connectSocket(accessToken)
    UI --> User : navigate → /match (auto-login)
    note right of UI
      main.jsx checks expiry on every page load
      No server call needed — JWT is self-contained
    end note
  end
else No token
  UI --> User : show username entry screen
end

' ═══════════════════════════════════════════════════════
== 🔐 STEP 2 — Username Claim ==
' ═══════════════════════════════════════════════════════

User -> UI : types username (live check as they type)

UI -> API : GET /api/users/check/:username (debounced 400ms)
note right of API
  No auth needed — public endpoint
  Validates: 3-20 chars, [a-z0-9_] only
end note

alt Username taken
  Backend --> API : { available: false, suggestions: ["alex_99",...] }
  API --> UI : response
  UI --> User : ❌ show suggestion pills
  User -> UI : clicks suggestion pill → fills input
else Username available
  Backend --> API : { available: true }
  API --> UI : response
  UI --> User : ✅ "Get started →" button enabled
end

User -> UI : toggles GPS (optional) + clicks "Get started →"

alt GPS toggle ON
  UI -> UI : navigator.geolocation.getCurrentPosition()
  UI --> User : browser asks location permission
end

UI -> API : POST /api/users/auth/register\n{ username, location? }
Backend --> API : 201 { data: user, accessToken }
API --> UI : response

UI -> Store : setAuth(user, accessToken)
note right of Store
  No refreshToken — sessions are temporary
  accessToken expires in SESSION_TTL_MS (15 min)
  Extended on every API call (keep-alive)
end note

UI -> Socket : connectSocket(accessToken)
note right of Socket
  Singleton — never replaced once created
  auth: { token: "Bearer <accessToken>" }
  Backend fetches TURN credentials from Metered.ca
  Caches pendingMatchFound + pendingPeerLeft globally
end note

Socket -> Backend : WebSocket handshake
Backend --> Socket : ice-config { iceServers: [STUN + TURN] }
note right of Socket
  TURN credentials from Metered.ca (server-side fetch)
  API key never sent to client
  Cached 12h on server
end note

UI --> User : navigate → /match

' ═══════════════════════════════════════════════════════
== 🎯 STEP 3 — Match Screen ==
' ═══════════════════════════════════════════════════════

UI --> User : show @username in nav\nmode cards + distance selector

note right of UI
  No separate preferences page
  Distance selector inline on Match screen
  GPS users: 4 options (Nearby/Neighborhood/City/Anywhere)
  IP users: fixed city-level note shown instead
end note

User -> UI : selects mode (📹 Video | 💬 Text)\n+ distance (GPS users only)\n+ clicks "Find a match →"

UI -> API : POST /api/match-requests\n{ mode: "video"|"text", maxDistanceMeters }
API -> Backend : fetch

alt 201 — instant match
  Backend --> API : { session, matchRequest }
  alt mode = "video"
    UI --> User : navigate → /call/:sessionId
  else mode = "text"
    UI --> User : navigate → /chat/:sessionId
  end

else 202 — searching
  Backend --> API : { matchRequest }
  UI --> User : pulse animation "Looking nearby..."
  note right of UI
    Two parallel fallbacks:
    1. socket "match-found" event (instant)
    2. poll GET /api/match-requests/:id every 2s
    Cancel button stops polling + cancels request
  end note

  Socket -> UI : match-found { sessionId, mode }
  note right of Socket
    Cached at socket.js level (pendingMatchFound)
    Checked on Match mount — never missed
    even with React StrictMode double-invoke
  end note
  alt mode = "video"
    UI --> User : navigate → /call/:sessionId
  else mode = "text"
    UI --> User : navigate → /chat/:sessionId
  end

else 409 — stale request
  Backend --> API : { data: existingRequest }
  API --> UI : err.status=409, err.data._id
  UI -> API : DELETE /api/match-requests/:id (cancel stale)
  UI -> API : POST /api/match-requests { mode, maxDistanceMeters } (retry)
  UI --> User : searching...
end

' ═══════════════════════════════════════════════════════
== 📹 STEP 4a — Video Call (/call/:sessionId) ==
' ═══════════════════════════════════════════════════════

UI -> UI : check pendingPeerLeft → /match?autostart if set
UI -> UI : getUserMedia({ video, audio })
UI --> User : local video preview (mirrored PiP)
UI -> UI : new RTCPeerConnection({ iceServers })
note right of UI
  iceServers from socket ice-config event
  Includes TURN credentials from Metered.ca
  TURN used automatically if STUN P2P fails
end note
UI -> Socket : emit("join-room", { sessionId })

Socket -> Backend : join-room
Backend --> Socket : peer-joined { userId: otherId } to BOTH peers

note over UI, Backend
  Deterministic offerer: myUserId < otherId → I create offer
  Prevents both peers creating offers simultaneously
  cancelled flag prevents stale async callbacks (StrictMode safe)
end note

alt I am offerer
  UI -> Socket : emit("offer", { sessionId, offer })
  Socket -> UI : answer { answer }
  UI -> UI : setRemoteDescription(answer)
else I am answerer
  Socket -> UI : offer { offer }
  UI -> UI : setRemoteDescription(offer) → createAnswer()
  UI -> Socket : emit("answer", { sessionId, answer })
end

UI -> Socket : emit("ice-candidate", ...) [multiple]
UI --> User : 🎥 remote video appears → connected

note right of UI
  Text chat panel (💬 button) — slides up on mobile, right on desktop
  Typing indicator: emit typing → peer-typing → bouncing dots
  Connection quality: pc.getStats() every 3s → 🟢🟡🔴
  Auto-reconnect: ICE drop → createOffer({ iceRestart: true })
  Block user: 🚫 → POST /api/users/block/:userId
  Session poll every 3s → /match?autostart if ended
end note

' ═══════════════════════════════════════════════════════
== 💬 STEP 4b — Text Chat (/chat/:sessionId) ==
' ═══════════════════════════════════════════════════════

UI -> UI : check pendingPeerLeft → /match?autostart if set
UI -> Socket : emit("join-room", { sessionId })
note right of UI
  No getUserMedia — no camera/mic
  No RTCPeerConnection — no WebRTC at all
  Pure socket messaging only
end note

Socket -> Backend : join-room
Backend --> Socket : peer-joined to both

UI --> User : 🟠 waiting → 🟢 connected (or 2s fallback timer)

User -> UI : types + sends message
UI -> Socket : emit("send-message", { sessionId, text })
Socket -> Backend : relay
Backend --> Socket : receive-message to other peer
UI --> User : bubble (mine=right/purple, theirs=left/dark)

note right of UI
  Typing indicator: emit typing → peer-typing → dots
  Session poll every 3s → /match?autostart if ended
end note

' ═══════════════════════════════════════════════════════
== 🔚 STEP 5 — End / Skip / Session Expiry ==
' ═══════════════════════════════════════════════════════

alt Skip ⏭ — find next match
  User -> UI : clicks Skip
  UI -> Socket : emit("leave-room")
  UI -> Backend : PATCH /api/sessions/:id/end { endReason: "skipped" }
  UI --> User : navigate → /match?autostart=video|text
  note right
    Match page reads ?autostart → auto-triggers doSearch(mode)
    Seamless next-match experience
  end note

else End 📵 — go to ended screen
  User -> UI : clicks End
  UI -> Socket : emit("leave-room")
  UI -> Backend : PATCH /api/sessions/:id/end { endReason: "completed" }
  UI --> User : navigate → /ended
  note right
    /ended: "That's a wrap 👋"
    "Chat again" → /match | "Go home" → /
  end note

else Peer left / disconnected
  Socket -> UI : peer-left { userId, endReason }
  note right of Socket
    Cached at socket.js level (pendingPeerLeft)
    Checked on Call/Chat mount — never missed
    Fallback: poll /api/sessions/:id every 3s
  end note
  UI --> User : navigate → /match?autostart=video|text

else Session token expires (15 min idle)
  UI -> API : any request → 401
  note right of API
    No refresh token — session is gone
    User must re-enter username
  end note
  API --> UI : 401
  UI -> Store : clearAuth()
  UI -> Socket : disconnectSocket()
  UI --> User : navigate → / (username screen)
  note right
    Username freed in MongoDB after SESSION_TTL_MS
    Anyone can claim it after expiry
  end note
end

' ═══════════════════════════════════════════════════════
== ⚡ QUICK REFERENCE ==
' ═══════════════════════════════════════════════════════

note over User, Backend
  <color:#16A085>PAGES & ROUTES</color>
  /                  Landing     — username entry + GPS toggle (public)
  /match             Match       — mode cards + distance + find match (Guard)
  /call/:sessionId   Call        — WebRTC video + text chat panel (Guard)
  /chat/:sessionId   Chat        — text-only fullscreen chat (Guard)
  /ended             Ended       — session ended screen (Guard)

  No /login, /register, /preferences, /profile pages
  Guard: no accessToken OR expired token → redirect /

  <color:#8E44AD>STATE (Zustand — persisted)</color>
  auth.store:  user, accessToken
               setAuth(user, accessToken) / clearAuth()
  theme.store: theme ("dark"|"light")
               toggle() — sets data-theme on html
               init()   — called in main.jsx on load
  No refreshToken — sessions are temporary

  <color:#E67E22>API CLIENT (api.js)</color>
  401 → clearAuth() + redirect / (no refresh attempt)
  429 → keep last known status (username check — don't block button)
  409 → err.status=409, err.data = existing resource
  All requests: Authorization: Bearer <token>

  <color:#1A5276>SOCKET CLIENT (socket.js)</color>
  Singleton — never replaced once created
  connectSocket(token) — returns existing if alive
  Caches: pendingMatchFound, pendingPeerLeft, pendingPeerJoined
  pendingPeerJoined fixes StrictMode WebRTC double-invoke
  On page load: main.jsx checks JWT expiry → connect or clearAuth

  <color:#C0392B>GUARDS</color>
  /match /call /chat /ended routes
  No accessToken OR JWT expired → redirect /
end note

@enduml
