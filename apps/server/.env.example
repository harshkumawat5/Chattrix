PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/chattrix
CLIENT_ORIGIN=http://localhost:5173
# For production, comma-separated: https://chattrix.vercel.app,https://chattrix-git-main.vercel.app

# JWT
JWT_SECRET=chattrix_jwt_secret_change_in_prod
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=chattrix_refresh_secret_change_in_prod
JWT_REFRESH_EXPIRES_IN=7d

# Rate limiting
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=400
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_MATCH_WINDOW_MS=60000
RATE_LIMIT_MATCH_MAX=15
RATE_LIMIT_MATCH_COOLDOWN_MS=2000
RATE_LIMIT_SOCKET_CONN_WINDOW_MS=60000
RATE_LIMIT_SOCKET_CONN_MAX=5
RATE_LIMIT_SOCKET_MSG_WINDOW_MS=1000
RATE_LIMIT_SOCKET_MSG_MAX=10

# GeoIP
GEOIP_API_TIMEOUT_MS=3000
GEOIP_DEFAULT_RADIUS_METERS=20000

# Match expiry job
MATCH_EXPIRY_INTERVAL_MS=30000
MATCH_REQUEST_TTL_MS=120000

# STUN servers (comma-separated)
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# TURN servers (comma-separated). Recommended for reliable P2P across NATs.
TURN_SERVERS=
TURN_USERNAME=
TURN_CREDENTIAL=

# Recording storage (S3-compatible)
RECORDING_PROVIDER=idrive_e2
RECORDING_S3_BUCKET=sahilbucket
RECORDING_S3_REGION=
RECORDING_S3_ACCESS_KEY_ID=
RECORDING_S3_SECRET_ACCESS_KEY=
# Optional for S3-compatible providers (IDrive E2, Cloudflare R2, MinIO, etc.)
RECORDING_S3_ENDPOINT=
RECORDING_S3_FORCE_PATH_STYLE=true
# Optional public URL base for stored files (otherwise standard S3 URL is used)
RECORDING_PUBLIC_BASE_URL=
RECORDING_UPLOAD_EXPIRES_SECONDS=900
