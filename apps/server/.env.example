PORT=3000
MONGODB_URI=mongodb://127.0.0.1:27017/chattrix
CLIENT_ORIGIN=http://localhost:5173
# Production: comma-separated origins
# CLIENT_ORIGIN=https://chattrix.vercel.app,https://chattrix-git-main.vercel.app

# ── JWT ──────────────────────────────────────────────────────────
JWT_SECRET=change_this_in_production
JWT_EXPIRES_IN=2h

# ── Session TTL ──────────────────────────────────────────────────
SESSION_TTL_MS=900000

# ── Rate limiting ────────────────────────────────────────────────
RATE_LIMIT_API_WINDOW_MS=900000
RATE_LIMIT_API_MAX=800
RATE_LIMIT_AUTH_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_CHECK_MAX=60
RATE_LIMIT_MATCH_WINDOW_MS=60000
RATE_LIMIT_MATCH_MAX=15
RATE_LIMIT_MATCH_COOLDOWN_MS=2000
RATE_LIMIT_SOCKET_CONN_WINDOW_MS=60000
RATE_LIMIT_SOCKET_CONN_MAX=5
RATE_LIMIT_SOCKET_MSG_WINDOW_MS=1000
RATE_LIMIT_SOCKET_MSG_MAX=20

# ── GeoIP ────────────────────────────────────────────────────────
GEOIP_API_TIMEOUT_MS=3000
GEOIP_DEFAULT_RADIUS_METERS=20000

# ── Match expiry job ─────────────────────────────────────────────
MATCH_EXPIRY_INTERVAL_MS=30000
MATCH_REQUEST_TTL_MS=120000

# ── WebRTC — STUN ────────────────────────────────────────────────
STUN_SERVERS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302,stun:stun2.l.google.com:19302,stun:stun3.l.google.com:19302,stun:stun4.l.google.com:19302

# ── WebRTC — TURN (Self-hosted Coturn on Azure/AWS/etc) ──────────
# Install Coturn on your VM, then add credentials here
TURN_SERVER_URL=turn:your-vm-ip:3478
TURN_USERNAME=your-turn-username
TURN_PASSWORD=your-turn-password

# ── Upstash Redis (free, no CC) — for horizontal scaling ─────────
# Sign up: https://console.upstash.com → Create Redis DB → copy URL
# Leave empty to run in single-instance mode (no scaling needed)
UPSTASH_REDIS_URL=


# ── Legal & Safety ───────────────────────────────────────────────
AUTO_BAN_BLOCK_COUNT=5

# ── AWS Rekognition — Video Frame Moderation ─────────────────────
# Set to false to disable moderation without removing credentials
MODERATION_ENABLED=false
#
# These AWS_* keys are for Rekognition ONLY (image moderation)
# Get from: AWS Console → IAM → Create user → AmazonRekognitionReadOnlyAccess
# Region: ap-south-1 (Mumbai) recommended for India
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Confidence threshold 0-100 — flag if nudity/explicit >= this value
MODERATION_CONFIDENCE_THRESHOLD=80
# How often client captures a frame (ms) — 30000 = every 30 seconds
MODERATION_FRAME_INTERVAL_MS=30000
