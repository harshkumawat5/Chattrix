VITE_API_URL=http://localhost:3000
VITE_SOCKET_URL=http://localhost:3000
# Production:
# VITE_API_URL=https://your-app.onrender.com
# VITE_SOCKET_URL=https://your-app.onrender.com

# ── Contact emails (shown on legal pages) ────────────────────────
VITE_EMAIL_GENERAL=hello@chattrix.app
VITE_EMAIL_LEGAL=legal@chattrix.app
VITE_EMAIL_SAFETY=safety@chattrix.app
VITE_EMAIL_PRIVACY=privacy@chattrix.app
VITE_EMAIL_GRIEVANCE=grievance@chattrix.app

# ── Google AdSense ───────────────────────────────────────────────
# Set to true to show ads, false to hide all ads instantly
VITE_ADS_ENABLED=false
# Your AdSense publisher ID — format: ca-pub-XXXXXXXXXXXXXXXXX
VITE_ADSENSE_CLIENT=ca-pub-0000000000000000
# Ad slot IDs — get from AdSense dashboard after creating ad units
VITE_AD_SLOT_LANDING=0000000000
VITE_AD_SLOT_MATCH=0000000001
